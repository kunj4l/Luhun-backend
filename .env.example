############################################
# Core application
############################################
NODE_ENV=development
PORT=4000
APP_NAME="Luhun's Official"
APP_URL=http://localhost:4000
ADMIN_URL=http://localhost:4000/admin
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:56609,https://classy-nougat-210126.netlify.app
LUHUN_CATALOG_DIR=./catalog
STORE_AUTO_SYNC=true

############################################
# Database
############################################
# SQLite (dev) — leave blank to use ./data.sqlite
SQLITE_PATH=./data.sqlite
# PostgreSQL (prod) — ONLY set on Render if you created a Render Postgres database.
# Do NOT paste the localhost example below into Render (it will crash the app).
# DATABASE_URL=postgres://user:password@localhost:5432/clothing_brand
DB_POOL_MAX=20
DB_POOL_MIN=0
DB_LOGGING=false

############################################
# Auth / Security
############################################
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=change-me-too
BCRYPT_ROUNDS=12
ACCOUNT_LOCK_THRESHOLD=5
ACCOUNT_LOCK_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

############################################
# Stripe
############################################
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=usd

############################################
# PayPal (REST API v2)
############################################
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENV=sandbox
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

############################################
# Square
############################################
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENV=sandbox

############################################
# Braintree
############################################
BRAINTREE_ENV=sandbox
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

############################################
# Klarna
############################################
KLARNA_USERNAME=
KLARNA_PASSWORD=
KLARNA_BASE_URL=https://api.playground.klarna.com

############################################
# Afterpay / Clearpay
############################################
AFTERPAY_MERCHANT_ID=
AFTERPAY_SECRET_KEY=
AFTERPAY_BASE_URL=https://api.us-sandbox.afterpay.com

############################################
# Coinbase Commerce (crypto)
############################################
COINBASE_API_KEY=
COINBASE_WEBHOOK_SECRET=

############################################
# Shipping
############################################
SHIPPO_API_KEY=
UPS_ACCESS_KEY=
UPS_USERNAME=
UPS_PASSWORD=
FEDEX_ACCOUNT_NUMBER=
FEDEX_METER_NUMBER=
FEDEX_API_KEY=
FEDEX_SECRET_KEY=
USPS_USER_ID=
DHL_API_KEY=
DEFAULT_SHIP_FROM_NAME="Brand HQ"
DEFAULT_SHIP_FROM_STREET="123 Market St"
DEFAULT_SHIP_FROM_CITY="New York"
DEFAULT_SHIP_FROM_STATE="NY"
DEFAULT_SHIP_FROM_ZIP="10001"
DEFAULT_SHIP_FROM_COUNTRY="US"

############################################
# Email / SMTP
############################################
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Clothing Brand <no-reply@example.com>"
LOW_STOCK_ALERT_EMAIL=ops@example.com

############################################
